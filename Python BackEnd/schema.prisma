datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-py"
}

model VerifiedClaim {
  id            String   @id @default(uuid())
  claim_hash    String   @unique
  original_text String
  verdict       String
  explanation   String
  source_links  String   // Store as JSON string
  createdAt     DateTime @default(now())
}
